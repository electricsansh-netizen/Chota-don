<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎂 Happy Birthday Chota Don!</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', 'Arial', sans-serif;
            background: linear-gradient(145deg, #f9e3e3 0%, #ffe6f0 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }
        /* Balloons animation */
        .balloon {
            position: absolute;
            bottom: -150px;
            width: 40px;
            height: 60px;
            background: #ff6b9d;
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            animation: float 6s ease-in infinite;
            opacity: 0.7;
            z-index: 0;
        }
        .balloon::before {
            content: "";
            position: absolute;
            bottom: -10px;
            left: 18px;
            width: 4px;
            height: 30px;
            background: #aaa;
        }
        .balloon:nth-child(1) { left: 10%; background: #ffb347; animation-duration: 7s; }
        .balloon:nth-child(2) { left: 30%; background: #6b8cff; animation-duration: 8s; width: 50px; height: 70px; }
        .balloon:nth-child(3) { left: 50%; background: #ff6f91; animation-duration: 9s; }
        .balloon:nth-child(4) { left: 70%; background: #a06bff; animation-duration: 7.5s; }
        .balloon:nth-child(5) { left: 90%; background: #ffb3ba; animation-duration: 8.5s; }
        @keyframes float {
            0% { transform: translateY(0) rotate(0deg); opacity: 0.7; }
            100% { transform: translateY(-120vh) rotate(10deg); opacity: 0.2; }
        }

        .card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 40px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2), 0 0 0 2px #fff inset;
            padding: 40px 30px;
            max-width: 700px;
            width: 100%;
            text-align: center;
            position: relative;
            z-index: 10;
            border: 1px solid rgba(255,255,240,0.6);
        }

        h1 {
            font-size: 3.2rem;
            color: #d44e6c;
            text-shadow: 3px 3px 0 #ffe0e7;
            margin-bottom: 10px;
            line-height: 1.2;
        }
        .nickname {
            font-size: 2.5rem;
            background: #ffe0a3;
            display: inline-block;
            padding: 10px 30px;
            border-radius: 60px;
            margin: 20px 0 10px;
            font-weight: bold;
            color: #a5435a;
            box-shadow: 0 4px 0 #c1a16b;
        }
        .from {
            font-size: 1.8rem;
            color: #4a2c3b;
            margin-bottom: 30px;
        }
        .from span {
            background: #c1e0ff;
            padding: 5px 25px;
            border-radius: 40px;
            display: inline-block;
        }

        .heart-message {
            background: #fff0f5;
            border-radius: 50px;
            padding: 25px;
            margin: 30px 0;
            border: 2px dashed #ff99aa;
            font-size: 1.3rem;
            line-height: 2;
            color: #2c3e50;
        }
        .heart-message p {
            margin: 10px 0;
        }
        .heart-message i {
            color: #e84342;
            font-size: 1.8rem;
        }

        .countdown-box {
            background: #fde4e4;
            border-radius: 40px;
            padding: 20px;
            margin: 30px 0;
        }
        #countdown {
            font-size: 2.2rem;
            font-weight: bold;
            color: #b34164;
            letter-spacing: 4px;
        }
        .birthday-note {
            font-size: 2rem;
            color: #b34164;
            font-weight: bold;
            display: none;
        }

        .button {
            background: #ff8a9f;
            border: none;
            color: white;
            font-size: 1.5rem;
            padding: 15px 40px;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 7px 0 #b35c71;
            transition: 0.1s ease;
            margin-top: 20px;
            border: 2px solid #fff;
            font-weight: bold;
        }
        .button:active {
            transform: translateY(5px);
            box-shadow: 0 2px 0 #b35c71;
        }

        .footer {
            margin-top: 30px;
            font-size: 1.2rem;
            color: #776871;
        }
        .footer i {
            color: red;
        }
    </style>
</head>
<body>
    <!-- Floating balloons -->
    <div class="balloon"></div>
    <div class="balloon"></div>
    <div class="balloon"></div>
    <div class="balloon"></div>
    <div class="balloon"></div>

    <div class="card">
        <h1>🎉 Happy Birthday 🎉</h1>
        <div class="nickname">Chota Don 💖</div>
        <div class="from"><span>Sanshu Bhaiya ki taraf se</span></div>

        <div class="heart-message">
            <p><i>💌</i></p>
            <p>प्यारी चोटा डॉन,</p>
            <p>आपके जन्मदिन पर मैं आपको बहुत-बहुत मुबारकबाद देता हूँ।</p>
            <p>आप हमेशा खुश रहें, स्वस्थ रहें, और भैया का ख़याल रखें।</p>
            <p>आप मेरे लिए सिर्फ भाभी नहीं, बल्कि एक सच्ची दोस्त और परिवार की सबसे प्यारी सदस्य हैं।</p>
            <p>आपकी हँसी से ही घर रोशन हो जाता है। चोटा डॉन, आप रॉक करती हो! 🌟</p>
            <p><i>💕 हमेशा अपने संशु भैया का प्यार आपके साथ है 💕</i></p>
        </div>

        <!-- Countdown till 25 March, if today is before 25th. Otherwise show birthday message -->
        <div class="countdown-box" id="countdownBox">
            <div id="countdown"></div>
            <div class="birthday-note" id="birthdayNote">🎂 आज का दिन है आपका! 🎂</div>
        </div>

        <!-- A cute click button for extra surprise -->
        <button class="button" onclick="showSurprise()">❤️ सरप्राइज खोलें ❤️</button>
        <p id="surpriseMessage" style="font-size:1.8rem; margin-top:20px; color:#b34164; display:none;">🎈 चोटा डॉन, आपको ढेर सारा प्यार! 🎈</p>

        <div class="footer">
            बने रहें इतनी ही प्यारी, हँसती-मुस्कुराती <i>❤️</i>
        </div>
    </div>

    <script>
        // Countdown to 25 March
        function updateCountdown() {
            const today = new Date();
            const currentYear = today.getFullYear();
            // Set birthday date (25 March of current year)
            let birthday = new Date(currentYear, 2, 25); // month is 0-indexed: 2 = March
            // If today is after March 25, use next year's birthday
            if (today > birthday) {
                birthday = new Date(currentYear + 1, 2, 25);
            }
            const diff = birthday - today;

            // If diff <= 0 (means it's birthday today or passed), show birthday message
            if (diff <= 0 && today.getDate() === 25 && today.getMonth() === 2) {
                document.getElementById('countdown').style.display = 'none';
                document.getElementById('birthdayNote').style.display = 'block';
            } else if (diff <= 0) {
                // If passed but not exactly today, still treat as birthday (for safety)
                document.getElementById('countdown').style.display = 'none';
                document.getElementById('birthdayNote').style.display = 'block';
            } else {
                // Calculate days, hours, minutes, seconds
                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((diff % (1000 * 60)) / 1000);

                document.getElementById('countdown').innerHTML = `${days}दिन ${hours}घं ${minutes}मि ${seconds}से`;
            }
        }

        // Run countdown every second
        setInterval(updateCountdown, 1000);
        updateCountdown();

        // Surprise button function
        function showSurprise() {
            const msg = document.getElementById('surpriseMessage');
            if (msg.style.display === 'none' || msg.style.display === '') {
                msg.style.display = 'block';
            } else {
                msg.style.display = 'none';
            }
        }

        // If today is 25 March, directly show birthday message and hide countdown
        (function() {
            const today = new Date();
            if (today.getDate() === 25 && today.getMonth() === 2) {
                document.getElementById('countdown').style.display = 'none';
                document.getElementById('birthdayNote').style.display = 'block';
            }
        })();
    </script>
</body>
</html>
